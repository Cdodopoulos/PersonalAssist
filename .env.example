# Configurações da Assistente - Jitro Layer
# Copie este arquivo para .env e preencha os valores

# Token do Bot Telegram (obtenha via @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI

# Chave de API do Google Gemini (obtenha em: aistudio.google.com)
GEMINI_API_KEY=AIzaSySuaChaveAqui

# Porta da API Jitro
JITRO_PORT=8000

# Modelo do Gemini para usar (ex: gemini-1.5-flash, gemini-1.5-pro)
MODEL_NAME=gemini-1.5-flash

# Caminho para banco de dados de memória
MEMORY_DB_PATH=./jitro_memory.db

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
